{
  "name": "cramer-short",
  "version": "2026.3.25",
  "description": "Cramer-Short - AI agent for deep financial research.",
  "type": "module",
  "main": "src/index.tsx",
  "bin": {
    "cramer-short": "./src/index.tsx"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun --watch run src/index.tsx",
    "gateway": "tsx src/gateway/index.ts run",
    "gateway:login": "tsx src/gateway/index.ts login",
    "typecheck": "tsc --noEmit",
    "test": "bun test --path-ignore-patterns='*.integration.test.ts' --path-ignore-patterns='*.e2e.test.ts'",
    "test:unit": "bun test --path-ignore-patterns='*.integration.test.ts' --path-ignore-patterns='*.e2e.test.ts'",
    "test:integration": "RUN_INTEGRATION=1 bun test --filter integration",
    "test:e2e": "RUN_E2E=1 bun test src/agent/agent.e2e.test.ts --timeout 360000 && RUN_E2E=1 bun test src/skills/dcf/skill.e2e.test.ts --timeout 360000 && RUN_E2E=1 bun test src/skills/probability-assessment/skill.e2e.test.ts --timeout 360000 && RUN_E2E=1 bun test src/model/llm.e2e.test.ts --timeout 360000 && RUN_E2E=1 bun test src/model/llm-streaming.e2e.test.ts --timeout 360000 && RUN_E2E=1 bun test src/memory/embeddings.e2e.test.ts --timeout 60000",
    "test:all": "bun run test:unit && bun run test:integration && bun run test:e2e",
    "test:watch": "bun test --watch",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.1.3",
    "@langchain/core": "^1.1.0",
    "@langchain/exa": "^1.0.1",
    "@langchain/google-genai": "^2.0.0",
    "@langchain/ollama": "^1.0.3",
    "@langchain/openai": "^1.1.3",
    "@langchain/tavily": "^1.0.1",
    "@mariozechner/pi-tui": "^0.52.9",
    "@mozilla/readability": "^0.6.0",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "better-sqlite3": "^12.6.2",
    "diff": "^8.0.3",
    "dotenv": "^17.2.3",
    "exa-js": "^2.2.0",
    "gray-matter": "^4.0.3",
    "langsmith": "^0.4.10",
    "linkedom": "^0.18.12",
    "playwright": "^1.52.0",
    "qrcode-terminal": "^0.12.0",
    "sqlite-vec": "^0.1.7",
    "unpdf": "^1.4.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/jest": "^29.5.14",
    "@types/qrcode-terminal": "^0.12.2",
    "babel-jest": "^30.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
